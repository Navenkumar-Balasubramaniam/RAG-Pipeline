# ============================================================
# Project data — never commit user PDFs, indices, or logs
# But keep the folder structure via .gitkeep files
# ============================================================
data/uploads/*
!data/uploads/.gitkeep

data/indices/*
!data/indices/.gitkeep

logs/*
!logs/.gitkeep

# ============================================================
# Model files (in case we ever download GGUF directly)
# Ollama stores models elsewhere, but just in case
# ============================================================
*.gguf
*.bin
*.safetensors
*.pt
*.pth

