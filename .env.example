# ============================================================
# Example environment configuration for rag-pipeline
#
# Copy this file to .env and fill in any project-specific values.
# All values shown here are the defaults from config.py.
# ============================================================

# ----- Logging -----
RAG_LOG_LEVEL=INFO

# ----- Ollama / LLM -----
RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_LLM_MODEL=mistral:7b-instruct
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_MAX_TOKENS=700

# ----- Query rewriting -----
# Set to false to skip query rewriting (saves one LLM call per question; faster on CPU)
RAG_ENABLE_QUERY_REWRITING=true

# ----- Retrieval -----
RAG_TOP_K_RETRIEVAL=5
RAG_TOP_N_RERANK=3